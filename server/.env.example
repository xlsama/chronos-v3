# Database (plain postgresql://, not postgresql+asyncpg://)
DATABASE_URL=postgresql://chronos:chronos@localhost:5432/chronos

# Redis
REDIS_URL=redis://localhost:6379/0

# DashScope / Bailian
DASHSCOPE_API_KEY=sk-xxx
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MAIN_MODEL=kimi-k2.5
MINI_MODEL=qwen3.5-flash
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024
RERANK_MODEL=qwen3-rerank
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
VISION_MODEL=qwen-vl-max

# Agent
AGENT_RECURSION_LIMIT=200
TOOL_CALL_MAX_RETRIES=2
COMMAND_TIMEOUT=10

# Cron
SKILL_EVOLUTION_INTERVAL=8

# Data
DATA_DIR=data
SEEDS_DIR=seeds

# Security — override in production
ENCRYPTION_KEY=your-32-byte-base64-encoded-key
JWT_SECRET=your-jwt-secret

# Server
PORT=8000
LOG_LEVEL=debug
